# Windows system files
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Ignore all environment files
*.env

# Except for the template file (which has no real keys)
!.env.example

# VS Code specific
.vscode/
*.code-workspace

# Temporary / Backup files
*.tmp
*.bak
*.log
*~

# Video/Large Media (Prevents accidental multi-GB uploads)
*.mp4
*.mkv
*.mov
*.avi
*.mp3
*.wav
